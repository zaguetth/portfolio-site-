<script>
/* ───────────────────────────────────────────
   Interactions
─────────────────────────────────────────── */

// Year
document.getElementById('yr').textContent = new Date().getFullYear();

// Live Manila time
function tick(){
  const now = new Date();
  const t = new Intl.DateTimeFormat('en-US',{
    hour:'2-digit',minute:'2-digit',timeZone:'Asia/Manila',hour12:false
  }).format(now);
  const el = document.getElementById('liveTime');
  if (el) el.textContent = `Live · Manila ${t}`;
}
tick(); setInterval(tick, 30000);

// Nav scroll state
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 30);
}, {passive:true});

// Reveal on scroll
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting){
      e.target.classList.add('in');
      io.unobserve(e.target);
    }
  });
}, {threshold:0.12, rootMargin:'0px 0px -10% 0px'});
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// Custom cursor (desktop / fine pointer only)
const fine = window.matchMedia('(hover:hover) and (pointer:fine)').matches;
if (fine){
  document.body.classList.add('has-cursor');
  const c = document.getElementById('cursor');
  document.addEventListener('pointermove', e => {
    c.classList.add('show');
    c.style.transform = `translate(${e.clientX}px, ${e.clientY}px) translate(-50%,-50%)`;
  });
  document.addEventListener('pointerleave', () => c.classList.remove('show'));
  document.querySelectorAll('[data-cursor]').forEach(el => {
    el.addEventListener('pointerenter', () => {
      c.classList.add('is-hover');
      c.setAttribute('data-label', el.getAttribute('data-cursor'));
    });
    el.addEventListener('pointerleave', () => c.classList.remove('is-hover'));
  });
}

// Work filters
const grid = document.getElementById('workGrid');
const projs = grid.querySelectorAll('.proj');
document.querySelectorAll('.work__filter').forEach(b => {
  b.addEventListener('click', () => {
    document.querySelectorAll('.work__filter').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    const f = b.dataset.filter;
    projs.forEach(p => {
      const show = (f === 'all') || p.dataset.cat === f;
      p.style.display = show ? '' : 'none';
    });
  });
});

// Testimonials nav
const rail = document.getElementById('testRail');
const card = rail.querySelector('.test__card');
document.getElementById('tprev').addEventListener('click', () => rail.scrollBy({left:-(card.offsetWidth+28), behavior:'smooth'}));
document.getElementById('tnext').addEventListener('click', () => rail.scrollBy({left: card.offsetWidth+28, behavior:'smooth'}));

// Contact form
const form = document.getElementById('contactForm');
form.addEventListener('submit', e => {
  e.preventDefault();
  if (!form.checkValidity()){
    form.reportValidity();
    return;
  }
  const ok = document.getElementById('success');
  ok.classList.add('show');
  form.reset();
  setTimeout(() => ok.classList.remove('show'), 6000);
});
</script>
