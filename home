  margin-top:8px;
}
.form__submit:hover{background:var(--paper);color:var(--ink);transform:translateY(-2px)}
.form__success{
  display:none;background:#243B2A;color:var(--paper);
  padding:18px 22px;border-radius:8px;
  font:500 13px/1.5 var(--sans);
}
.form__success.show{display:block;animation:up .5s ease both}
@keyframes up{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ── Footer ─────────────────────────── */
