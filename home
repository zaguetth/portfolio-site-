.contact__desc{color:#C8BFA8;font-size:18px;max-width:42ch;margin-bottom:40px}

.contact__channels{display:flex;flex-direction:column;gap:14px;margin-bottom:32px}
.channel{
  display:flex;justify-content:space-between;align-items:center;gap:18px;
  padding:18px 0;border-top:1px solid #3a342b;
  font:500 13px/1 var(--mono);letter-spacing:.12em;text-transform:uppercase;
  color:var(--paper);transition:padding .3s;
}
.channel:last-child{border-bottom:1px solid #3a342b}
.channel:hover{padding-left:8px}
.channel__lbl{color:#8B7E68}
.channel__val{display:flex;align-items:center;gap:10px;color:var(--paper)}
.channel:hover .channel__val{color:var(--accent)}

.form{display:flex;flex-direction:column;gap:20px;background:#1c1813;padding:36px;border:1px solid #3a342b}
.form__row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:560px){.form__row{grid-template-columns:1fr}}
.field{display:flex;flex-direction:column;gap:8px}
.field label{font:500 11px/1 var(--mono);letter-spacing:.14em;text-transform:uppercase;color:#8B7E68}
.field input,.field textarea,.field select{
  background:transparent;border:none;border-bottom:1px solid #3a342b;
  color:var(--paper);font:400 16px/1.4 var(--sans);
  padding:10px 0;outline:none;transition:border-color .25s;font-family:var(--sans);
}
.field input:focus,.field textarea:focus,.field select:focus{border-color:var(--accent)}
.field textarea{resize:vertical;min-height:80px}
.field select{appearance:none;-webkit-appearance:none;background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path d='M1 1l5 5 5-5' stroke='%23FBF7EE' stroke-width='1.5' fill='none' stroke-linecap='round'/></svg>");background-repeat:no-repeat;background-position:right 0 center;padding-right:24px}
.field select option{background:#1c1813;color:var(--paper)}

.form__submit{
  display:inline-flex;align-items:center;justify-content:center;gap:10px;
  padding:18px 24px;background:var(--accent);color:var(--paper);
  font:500 12px/1 var(--mono);letter-spacing:.16em;text-transform:uppercase;
