.process{background:var(--bg-tint);max-width:none;padding:0;margin:0}
.process__inner{max-width:var(--max);margin:0 auto;padding:120px var(--pad)}
.process__head{
  font:300 italic clamp(48px,7vw,96px)/.95 var(--display);
  font-variation-settings:"opsz" 144,"SOFT" 60;
  letter-spacing:-.04em;max-width:14ch;margin-bottom:48px;
}
.process__head em{color:var(--accent);font-weight:700}
.process__steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-top:1px solid var(--ink)}
@media(max-width:880px){.process__steps{grid-template-columns:1fr}}
.step{padding:32px 24px 32px 0;border-bottom:1px solid var(--ink);position:relative}
.step:not(:last-child){border-right:1px solid var(--ink);padding-right:24px;padding-left:24px}
@media(max-width:880px){.step{padding:24px 0;border-right:none}.step:not(:last-child){padding:24px 0}}
.step__num{
  font:300 italic 56px/1 var(--display);
  font-variation-settings:"opsz" 144,"SOFT" 80;
  color:var(--accent);margin-bottom:16px;
}
.step__name{font:600 17px/1.2 var(--sans);margin-bottom:8px}
.step__copy{color:var(--ink-soft);font-size:15px}

/* ── Contact ─────────────────────────── */
.contact{
  background:var(--ink);color:var(--paper);max-width:none;padding:0;
}
.contact__inner{
